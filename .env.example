# Required — Vercel Postgres / Neon connection string
POSTGRES_URL="postgres://user:password@host/db"

# Optional — protects trainer dashboard and admin API endpoints
ADMIN_PASSWORD="change-me"

# Optional — enables AI-powered question extraction from messy PDF/Word files
# If not set, only structured parsing is used (works great for well-formatted docs)
OPENAI_API_KEY=""
